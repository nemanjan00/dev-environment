#!/bin/bash
set -euo pipefail

PROJECT_DIR="$(pwd)"
DOCKER_ARGS="-ti --pull always -e TERM=xterm-256color"

# Mount project
DOCKER_ARGS="$DOCKER_ARGS -v $PROJECT_DIR:/work/project"

# Auth: API key
if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
  DOCKER_ARGS="$DOCKER_ARGS -e ANTHROPIC_API_KEY"
fi

# Copy config files to a temp dir and mount that instead of individual files.
# Single-file bind mounts break on macOS when the file is replaced (new inode).
TMPDIR_CONFIG="$(mktemp -d /tmp/claude-docker.XXXXXX)"
trap 'rm -rf "$TMPDIR_CONFIG"' EXIT

INIT_CMDS=""

# Auth: OAuth credentials
if [ -f "${HOME}/.claude.json" ]; then
  cp "${HOME}/.claude.json" "$TMPDIR_CONFIG/claude.json"
  INIT_CMDS="$INIT_CMDS ln -sf /tmp/claude-config/claude.json /work/.claude.json ;"
fi

# Git config
if [ -f "${HOME}/.gitconfig" ]; then
  cp "${HOME}/.gitconfig" "$TMPDIR_CONFIG/gitconfig"
  INIT_CMDS="$INIT_CMDS ln -sf /tmp/claude-config/gitconfig /work/.gitconfig ;"
fi

DOCKER_ARGS="$DOCKER_ARGS -v $TMPDIR_CONFIG:/tmp/claude-config"

# Claude config directory (settings, memory, commands)
if [ -d "${HOME}/.claude" ]; then
  DOCKER_ARGS="$DOCKER_ARGS -v ${HOME}/.claude:/work/.claude"
fi

# Parse arguments
CLAUDE_ARGS=""
PROFILE="default"
while [ $# -gt 0 ]; do
  case "$1" in
    --host-network)
      DOCKER_ARGS="$DOCKER_ARGS --network host"
      ;;
    --profile)
      PROFILE="$2"
      shift
      ;;
    *)
      CLAUDE_ARGS="$CLAUDE_ARGS $1"
      ;;
  esac
  shift
done

IMAGE="nemanjan00/dev:${PROFILE}"

# Profile-specific mounts
if [ "$PROFILE" = "android" ]; then
  # Persistent ccache — AOSP builds are unusable without it across runs
  HOST_CCACHE="${HOME}/.cache/android-ccache"
  mkdir -p "$HOST_CCACHE"
  DOCKER_ARGS="$DOCKER_ARGS -v $HOST_CCACHE:/work/.ccache"
fi

# Run container (no exec — we need to copy config back after exit)
docker run $DOCKER_ARGS "$IMAGE" zsh -ic "$INIT_CMDS cd project ; tmux new-session 'claude --dangerously-skip-permissions $CLAUDE_ARGS'"

# Persist updated OAuth credentials back to host
if [ -f "$TMPDIR_CONFIG/claude.json" ]; then
  cp "$TMPDIR_CONFIG/claude.json" "${HOME}/.claude.json"
fi
