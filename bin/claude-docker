#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Self-update: fast-forward the wrappers/profiles on launch so everyone runs
# the latest. Best-effort — a missing network, local commits, or a dirty tree
# all just skip it; a launch is never blocked. Opt out with DEV_NO_UPDATE=1.
# On an actual update we re-exec so this very launch uses the new version;
# DEV_UPDATED guards against a re-exec loop.
if [ "${DEV_NO_UPDATE:-0}" != "1" ] && [ -z "${DEV_UPDATED:-}" ] && [ -d "$SCRIPT_DIR/.git" ]; then
  before="$(git -C "$SCRIPT_DIR" rev-parse HEAD 2>/dev/null || true)"
  git -C "$SCRIPT_DIR" pull --ff-only --quiet 2>/dev/null || true
  after="$(git -C "$SCRIPT_DIR" rev-parse HEAD 2>/dev/null || true)"
  if [ -n "$before" ] && [ "$before" != "$after" ]; then
    echo "dev-environment: updated to $(git -C "$SCRIPT_DIR" rev-parse --short HEAD), relaunching..." >&2
    exec env DEV_UPDATED=1 "${BASH_SOURCE[0]}" "$@"
  fi
fi

PROJECT_DIR="$(pwd)"
# --rm: the container is throwaway — project, config and auth are bind mounts
# (and updated OAuth is copied back from the temp dir after exit), so nothing
# of value lives in the container itself. Removing it on exit keeps stopped
# containers from piling up.
DOCKER_ARGS="-ti --rm --pull always -e TERM=xterm-256color"

# Mount project
DOCKER_ARGS="$DOCKER_ARGS -v $PROJECT_DIR:/work/project"

# Expose host project path so the in-container tmux status line can show
# which sandbox is which when several are running side by side. Collapse
# the host $HOME prefix to ~ here — inside the container $HOME is /work,
# so the substitution has to happen on the host.
HOST_PROJECT_DISPLAY="$PROJECT_DIR"
case "$PROJECT_DIR" in
  "$HOME") HOST_PROJECT_DISPLAY="~" ;;
  "$HOME"/*) HOST_PROJECT_DISPLAY="~${PROJECT_DIR#$HOME}" ;;
esac
DOCKER_ARGS="$DOCKER_ARGS -e HOST_PROJECT_DIR=$HOST_PROJECT_DISPLAY"

# Auth: API key
if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
  DOCKER_ARGS="$DOCKER_ARGS -e ANTHROPIC_API_KEY"
fi

# Copy config files to a temp dir and mount that instead of individual files.
# Single-file bind mounts break on macOS when the file is replaced (new inode).
TMPDIR_CONFIG="$(mktemp -d /tmp/claude-docker.XXXXXX)"
trap 'rm -rf "$TMPDIR_CONFIG"' EXIT

INIT_CMDS=""

# Auth: OAuth credentials
if [ -f "${HOME}/.claude.json" ]; then
  cp "${HOME}/.claude.json" "$TMPDIR_CONFIG/claude.json"
  INIT_CMDS="$INIT_CMDS ln -sf /tmp/claude-config/claude.json /work/.claude.json ;"
fi

# Git config
if [ -f "${HOME}/.gitconfig" ]; then
  cp "${HOME}/.gitconfig" "$TMPDIR_CONFIG/gitconfig"
  INIT_CMDS="$INIT_CMDS ln -sf /tmp/claude-config/gitconfig /work/.gitconfig ;"
fi

DOCKER_ARGS="$DOCKER_ARGS -v $TMPDIR_CONFIG:/tmp/claude-config"

# Claude config directory (settings, memory, commands)
if [ -d "${HOME}/.claude" ]; then
  DOCKER_ARGS="$DOCKER_ARGS -v ${HOME}/.claude:/work/.claude"
  # Also mount at the host's absolute path so plugin entries that record
  # absolute paths (e.g. ${HOME}/.claude/plugins/...) resolve inside the
  # container without rewriting.
  if [ "${HOME}/.claude" != "/work/.claude" ]; then
    DOCKER_ARGS="$DOCKER_ARGS -v ${HOME}/.claude:${HOME}/.claude"
  fi
  # Per-host-path project bucket: each host project gets its own memory and
  # sessions, while the container always sees -work-project.
  HOST_SLUG="$(echo "$PROJECT_DIR" | tr / -)"
  HOST_BUCKET="${HOME}/.claude/projects/${HOST_SLUG}"
  mkdir -p "$HOST_BUCKET"
  DOCKER_ARGS="$DOCKER_ARGS -v $HOST_BUCKET:/work/.claude/projects/-work-project"
fi

# Parse arguments
CLAUDE_ARGS=""
PROFILE="default"
while [ $# -gt 0 ]; do
  case "$1" in
    --host-network)
      DOCKER_ARGS="$DOCKER_ARGS --network host"
      ;;
    --profile)
      PROFILE="$2"
      shift
      ;;
    *)
      CLAUDE_ARGS="$CLAUDE_ARGS $1"
      ;;
  esac
  shift
done

IMAGE="nemanjan00/dev:${PROFILE}"

# Profile hook: if profiles/<name>/docker-args.sh exists and is executable,
# run it and append its stdout to DOCKER_ARGS. Lets each profile declare
# its own bind mounts / env vars without touching this script.
PROFILE_HOOK="$SCRIPT_DIR/profiles/$PROFILE/docker-args.sh"
if [ -x "$PROFILE_HOOK" ]; then
  DOCKER_ARGS="$DOCKER_ARGS $("$PROFILE_HOOK")"
fi

# Run container (no exec — we need to copy config back after exit)
# mcp.d/*.json expands inside tmux's child zsh (host bash + outer zsh -ic
# both see it quoted). zsh's NOMATCH aborts launch if mcp.d/ is empty —
# base image must always ship at least one .json file.
# --add-dir /work/skills: auto-load skills baked into the image at build time
# (under /work/skills/.claude/skills/) without writing into the host-mounted
# ~/.claude. Profiles populate it; base ships it empty. See root CLAUDE.md.
docker run $DOCKER_ARGS "$IMAGE" zsh -ic "$INIT_CMDS cd project ; tmux new-session 'claude --dangerously-skip-permissions --add-dir /work/skills --mcp-config /work/.config/claude/mcp.d/*.json $CLAUDE_ARGS'"

# Persist updated OAuth credentials back to host
if [ -f "$TMPDIR_CONFIG/claude.json" ]; then
  cp "$TMPDIR_CONFIG/claude.json" "${HOME}/.claude.json"
fi
