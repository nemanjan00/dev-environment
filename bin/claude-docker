#!/bin/bash
set -euo pipefail

PROJECT_DIR="$(pwd)"
DOCKER_ARGS="-ti -e TERM=xterm-256color"

# Mount project
DOCKER_ARGS="$DOCKER_ARGS -v $PROJECT_DIR:/work/project"

# Auth: API key
if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
  DOCKER_ARGS="$DOCKER_ARGS -e ANTHROPIC_API_KEY"
fi

# Auth: OAuth credentials
if [ -f "${HOME}/.claude.json" ]; then
  DOCKER_ARGS="$DOCKER_ARGS -v ${HOME}/.claude.json:/work/.claude.json"
fi

# Claude config directory (settings, memory, commands)
if [ -d "${HOME}/.claude" ]; then
  DOCKER_ARGS="$DOCKER_ARGS -v ${HOME}/.claude:/work/.claude"
fi

# Git config
if [ -f "${HOME}/.gitconfig" ]; then
  DOCKER_ARGS="$DOCKER_ARGS -v ${HOME}/.gitconfig:/work/.gitconfig:ro"
fi

# Parse arguments
CLAUDE_ARGS=""
PROFILE="default"
while [ $# -gt 0 ]; do
  case "$1" in
    --host-network)
      DOCKER_ARGS="$DOCKER_ARGS --network host"
      ;;
    --profile)
      PROFILE="$2"
      shift
      ;;
    *)
      CLAUDE_ARGS="$CLAUDE_ARGS $1"
      ;;
  esac
  shift
done

IMAGE="nemanjan00/dev:${PROFILE}"

exec docker run $DOCKER_ARGS "$IMAGE" zsh -ic "cd project ; tmux new-session 'claude --dangerously-skip-permissions $CLAUDE_ARGS'"
