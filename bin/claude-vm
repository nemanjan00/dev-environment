#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# PROJECT_DIR: env var > current directory
PROJECT_DIR="${PROJECT_DIR:-$(pwd)}"

cd "$SCRIPT_DIR"

# Unique ID per invocation so multiple VMs can run in parallel
export VM_ID="dev-$(head -c 4 /dev/urandom | xxd -p)"
export VAGRANT_DOTFILE_PATH="/tmp/vagrant-${VM_ID}"

# Ensure cleanup on exit (even on error or Ctrl-C)
cleanup() {
  vagrant destroy -f 2>/dev/null || true
  rm -rf "$VAGRANT_DOTFILE_PATH"
}
trap cleanup EXIT

# Export project dir for Vagrant
export PROJECT_DIR

# Claude config: env var > auto-detect ~/.claude
if [ -z "${CLAUDE_CONFIG_DIR:-}" ] && [ -d "${HOME}/.claude" ]; then
  CLAUDE_CONFIG_DIR="${HOME}/.claude"
fi
if [ -n "${CLAUDE_CONFIG_DIR:-}" ] && [ -d "$CLAUDE_CONFIG_DIR" ]; then
  export CLAUDE_CONFIG_DIR
fi

# Claude auth: env var > auto-detect ~/.claude.json
CLAUDE_AUTH="${CLAUDE_AUTH:-}"
if [ -z "$CLAUDE_AUTH" ] && [ -f "${HOME}/.claude.json" ]; then
  CLAUDE_AUTH="${HOME}/.claude.json"
fi

vagrant up

# Copy credentials into VM
if [ -n "$CLAUDE_AUTH" ] && [ -f "$CLAUDE_AUTH" ]; then
  vagrant ssh -c "cat > /tmp/.claude.json" < "$CLAUDE_AUTH"
fi

# Copy git config into VM if available
if [ -f "${HOME}/.gitconfig" ]; then
  vagrant ssh -c "cat > /tmp/.gitconfig" < "${HOME}/.gitconfig"
fi

# Build docker run command
DOCKER_ARGS="-ti -e TERM=xterm-256color"
DOCKER_ARGS="$DOCKER_ARGS -v /var/run/docker.sock:/var/run/docker.sock --group-add \$(stat -c '%g' /var/run/docker.sock)"

# Mount project — use /vagrant if PROJECT_DIR is the same as SCRIPT_DIR
if [ "$(realpath "$PROJECT_DIR")" = "$(realpath "$SCRIPT_DIR")" ]; then
  DOCKER_ARGS="$DOCKER_ARGS -v /vagrant:/work/project"
else
  DOCKER_ARGS="$DOCKER_ARGS -v /project:/work/project"
fi

if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
  DOCKER_ARGS="$DOCKER_ARGS -e ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY"
fi

if [ -n "${CLAUDE_CONFIG_DIR:-}" ]; then
  DOCKER_ARGS="$DOCKER_ARGS -v /claude-config:/work/.claude"
  # Per-host-path project bucket: each host project gets its own memory and
  # sessions, while the container always sees -work-project. Slug is computed
  # from the host PROJECT_DIR; the bucket is created host-side so the
  # synced_folder of CLAUDE_CONFIG_DIR makes it visible inside the VM at
  # /claude-config/projects/<slug>.
  HOST_SLUG="$(echo "$PROJECT_DIR" | tr / -)"
  mkdir -p "${CLAUDE_CONFIG_DIR}/projects/${HOST_SLUG}"
  DOCKER_ARGS="$DOCKER_ARGS -v /claude-config/projects/${HOST_SLUG}:/work/.claude/projects/-work-project"
fi

if [ -n "$CLAUDE_AUTH" ] && [ -f "$CLAUDE_AUTH" ]; then
  DOCKER_ARGS="$DOCKER_ARGS -v /tmp/.claude.json:/work/.claude.json"
fi

if [ -f "${HOME}/.gitconfig" ]; then
  DOCKER_ARGS="$DOCKER_ARGS -v /tmp/.gitconfig:/work/.gitconfig:ro"
fi

# Parse arguments
PROFILE="default"
CLAUDE_ARGS=""
ORIG_ARGS=("$@")
while [ $# -gt 0 ]; do
  case "$1" in
    --profile)
      PROFILE="$2"
      shift
      ;;
    *)
      CLAUDE_ARGS="$CLAUDE_ARGS $1"
      ;;
  esac
  shift
done

IMAGE="nemanjan00/dev:${PROFILE}"

vagrant ssh -c "docker run $DOCKER_ARGS $IMAGE zsh -ic 'cd project ; tmux new-session \"claude --dangerously-skip-permissions $CLAUDE_ARGS\"'"
